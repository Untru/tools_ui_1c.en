mennoyBazy);\nKonetsEsli;\nKonetsProtsedury\nFunktsiya SobratVozmozhnyeKatalogiUstanovkiPlatformyWindows()\nSI \= New SistemnayaInformatsiya;\nIshchem In raspolozheniyakh To Vista T Higher.\nZhelayushchie podderzhat puti In Windows XP - welcome\nKatalogVsePolzovateli \= SI.PoluchitPeremennuyuSredy("ALLUSERSPROFILE");\nKatalogTekushchegoPolzovatelya \= SI.PoluchitPeremennuyuSredy("APPDATA");\nMassivPutey \= New Array;\nSuffiksRaspolozheniya \= "1C\\1CEStart\\1CEStart.cfg";\nObshchiyKonfig \= SavedToolsDataCatalogNameAtServer(KatalogVsePolzovateli, SuffiksRaspolozheniya);\nDopolnitMassivRaspolozheniyIzKonfiguratsionnogoFayla(ObshchiyKonfig, MassivPutey);\nPolzovatelskiyKonfig \= SavedToolsDataCatalogNameAtServer(KatalogTekushchegoPolzovatelya, SuffiksRaspolozheniya);\nDopolnitMassivRaspolozheniyIzKonfiguratsionnogoFayla(PolzovatelskiyKonfig, MassivPutey);\nVozvrat MassivPutey;\nKonetsFunktsii\nProtsedura DopolnitMassivRaspolozheniyIzKonfiguratsionnogoFayla(Znach ImyaFayla, Znach MassivPutey)\nFaylKonfiga \= New File(ImyaFayla);\nEsli Dont FaylKonfiga.Exists() Togda\nLog.Debug("Konfiguratsionnyy File " + ImyaFayla + " Dont Found.");\nVozvrat;\nKonetsEsli;\nLog.Debug("Chitayu konfiguratsionnyy File " + ImyaFayla + ".");\nKonfig \= New KonfiguratsiyaStartera;\nKonfig.Open(ImyaFayla);\nZnacheniya \= Konfig.PoluchitSpisok("InstalledLocation");\nEsli Form <> Neopredeleno Togda\nDlya Kazhdogo Path From Form Tsikl\nMassivPutey.Add(Path);\nKonetsTsikla;\nKonetsEsli;\nKonetsProtsedury\n\nSluzhebnye Procedures
Comment.Программный\ интерфейс\nФункция\ ПолучитьВерсиюИзХранилища(Знач\ СтрокаСоединения,\ Знач\ ПользовательХранилища,\ Знач\ ПарольХранилища,\ Знач\ НомерВерсии\ \=\ Neopredeleno)\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/ConfigurationRepositoryF\ """+StrokaSoedineniya+"""");\nParametry\.Add("/ConfigurationRepositoryN\ """+PolzovatelKhranilishcha+"""");\nEsli\ Dont\ PustayaStroka(ParolKhranilishcha)\ Togda\nParametry\.Add("/ConfigurationRepositoryP\ """+ParolKhranilishcha+"""");\nKonetsEsli;\nFaylRezultata\ \=\ SavedToolsDataCatalogNameAtServer(KatalogSborki(),\ "Source\.cf");\nParametry\.Add("/ConfigurationRepositoryDumpCfg\ """+FaylRezultata\ +\ """");\nEsli\ Dont\ PustayaStroka(NomerVersii)\ Togda\nParametry\.Add("-v\ "+NomerVersii);\nKonetsEsli;\nVypolnitKomandu(Parameters);\nVozvrat\ FaylRezultata;\nKonetsFunktsii\nProtsedura\ SozdatFaylyPostavki(Znach\ PutFaylaPolnoyPostavki\ \="",\nznach\ PutFaylaPostavkiObnovleniya\ \=\ "",\nZnach\ DistributivyDlyaObnovleniya\ \=\ Neopredeleno,\ //\ Array\ Collection\ distributiva\ cf\nZnach\ PutFaylaSParametramiLitsenzirovaniya\ \=\ "")\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/CreateDistributionFiles\ ");\nEsli\ Dont\ ZnachenieZapolneno(PutFaylaPolnoyPostavki)\nI\ Dont\ ZnachenieZapolneno(PutFaylaPostavkiObnovleniya)\ Togda\nVyzvatIsklyuchenie\ "Dont\ pravilno\ zadany\ Parameters\ Procedures\ <"\ +\ "SozdatFaylyPostavki"\ +">";\nKonetsEsli;\nEsli\ ZnachenieZapolneno(PutFaylaPolnoyPostavki)\ Togda\nParametry\.Add("-cffile\ "+WrapInOuotationMarks(PutFaylaPolnoyPostavki)+"\ ");\nKonetsEsli;\nEsli\ ZnachenieZapolneno(PutFaylaPostavkiObnovleniya)\nI\ Dont\ DistributivyDlyaObnovleniya\ \=\ Neopredeleno\nI\ DistributivyDlyaObnovleniya\.Processed()\ >\ 0\ Togda\nParametry\.Add("-cfufile\ "+WrapInOuotationMarks(PutFaylaPostavkiObnovleniya)+"\ ");\nPodderzhivayutsya\ Only\ Files\ cf\nDlya\ kazhdogo\ DistributivObnovleniya\ From\ DistributivyDlyaObnovleniya\ Tsikl\nParametry\.Add("-f\ "+WrapInOuotationMarks(DistributivObnovleniya)+"\ ");\nKonetsTsikla;\nKonetsEsli;\nEsli\ ZnachenieZapolneno(PutFaylaSParametramiLitsenzirovaniya)\ Togda\nParametry\.Add("-digisign\ "+WrapInOuotationMarks(PutFaylaSParametramiLitsenzirovaniya)+"\ ");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ SozdatFaylovoeKhranilishcheKonfiguratsii(Znach\ PapkaKhranilishcha,\nZnach\ PolzovatelKhranilishcha,\nZnach\ ParolKhranilishcha\ \=\ "",\nznach\ PodklyuchitBazuKKhranilishchyu\ \=\ Lozh)\ Export\nObespechitKatalog(PapkaKhranilishcha);\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/ConfigurationRepositoryF\ """+PapkaKhranilishcha+"""");\nParametry\.Add("/ConfigurationRepositoryN\ """+PolzovatelKhranilishcha+"""");\nEsli\ Dont\ PustayaStroka(ParolKhranilishcha)\ Togda\nParametry\.Add("/ConfigurationRepositoryP\ """+ParolKhranilishcha+"""");\nKonetsEsli;\nParametry\.Add("/ConfigurationRepositoryCreate\ ");\nParametry\.Add("-AllowConfigurationChanges");\nParametry\.Add("-ChangesAllowedRule\ ObjectNotSupported");\nParametry\.Add("-ChangesNotRecommendedRule\ ObjectNotSupported");\nEsli\ PodklyuchitBazuKKhranilishchyu\ \=\ Lozh\ Togda\nParametry\.Add("-NoBind");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ OtklyuchitsyaOtKhranilishcha()\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/ConfigurationRepositoryUnbindCfg\ -force\ ");\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ VygruzitKonfiguratsiyuVFayly(Znach\ KatalogVygruzki,\ Znach\ FormatVygruzki\ \=\ "")\ Export\nEsli\ Dont\ ZnachenieZapolneno(FormatVygruzki)\ Togda\nFormatVygruzki\ \=\ RezhimVygruzkiKonfiguratsii\.Ierarkhicheskiy;\nKonetsEsli;\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add(StrShablon("/DumpConfigToFiles\ %1\ -Format\ %2",\ WrapInOuotationMarks(KatalogVygruzki),\ FormatVygruzki));\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ ZagruzitKonfiguratsiyuIzFayla(Znach\ FaylKonfiguratsii,\ Znach\ ObnovitKonfiguratsiyuIB\ \=\ Lozh)\ Export\nVypolnyaem\ Import\ T\ Update\ Period\ dva\ Wizard,\ Config\.S\.\ninogda\ Update\ L\ IB\ To\ novoy\ Base\ prokhodit\ neudachno,\nesli\ Run\ dve\ Operation\ In\ One\ komande\.\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/LoadCfg\ """\ +\ FaylKonfiguratsii\ +\ """");\nVypolnitKomandu(Parameters);\nEsli\ ObnovitKonfiguratsiyuIB\ Togda\nObnovitKonfiguratsiyuBazyDannykh(Lozh,\ Istina);\nKonetsEsli;\nKonetsProtsedury\nProtsedura\ VygruzitKonfiguratsiyuVFayl(Znach\ FaylKonfiguratsii)\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/DumpCfg\ """\ +\ FaylKonfiguratsii\ +\ """");\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nVypolnit\ Union\ Panel\ L\ C\ faylom\ (C\ ispolzovaniem\ Log\ Manager)\nOpisanie\ ITS\:\ http\://its\.1c\.ru/db/v83doc\#bookmark\:adm\:TI000000527\n\nParametry\:\nFaylKonfiguratsii\ -\ String\ -\ Name\ cf-Log\ C\ obedinyaemoy\ konfiguratsiey\.\nFaylNastroek\ -\ String\ -\ Name\ Log\ C\ nastroykami\ obedineniya\ konfiguratsiy\.\nPostavitNaPodderzhku\ -\ Boolean,\ Neopredeleno\ -\ Handlers\ Completion\ Rights\ L\ To\ podderzhku\.\n\t\tNeopredeleno\:\ By\ Default\ Handlers\ Dont\ peredaetsya\.\n\t\tIstina\:\ Group configuration\ stavitsya\ To\ podderzhku,\ If\ Has\ takaya\ vozmozhnost\.\n\t\tLozh\:\ Group configuration\ Dont\ stavitsya\ To\ podderzhku,\ dazhe\ If\ Has\ takaya\ vozhzmozhnost\.\nVklyuchitVObedinenieObektyPoNerazreshennymSsylkam\ -\ Boolean,\ Neopredeleno\ -\ Handlers\ nebkhodimosti\ New\n\t\tv\ Union\ Writing,\ Dont\ vklyuchennykh\ In\ Tasks\ obedinyaemykh\ T\ otsutstvuyushchikh\ In\ Main\ L\.\n\t\tNeopredeleno\:\ By\ Default\ Handlers\ Dont\ peredaetsya\.\n\t\tIstina\:\ vklyuchat\ Objects\ C\ nerazreshennymi\ ssylkami\ In\ Tasks\ obedinyaemykh\.\n\t\tLozh\:\ Clear\ References\ To\ Objects\ C\ nerazreshennymi\ ssylkami\.\nPrinuditelno\ -\ Boolean\ -\ Handlers\ prinuditelnogo\ Update\.\n\t\tObnovlenie\ budet\ proizvoditsya\ In\ sluchae\ Setting\:\n\t\t\tpreduprezhdeniy\ On\ udalyaemykh\ Writing,\ To\ kotorye\ Has\ References\ In\ obektakh,\n\t\t\t\tne\ uchastvuyushchikh\ In\ obedinenii\ (takie\ Objects\ budut\ isklyucheny\ From\ obedineniya);\n\t\t\tpreduprezhdeniy\ D\ primenenii\ Manager\.\n\t\tEsli\ Dont\ ukazan,\ to\ Union\ budet\ prervano\ In\ vysheukazannykh\ sluchayakh\.\n\nProtsedura\ ObedinitKonfiguratsiyuSFaylom(Znach\ FaylKonfiguratsii,\nZnach\ FaylNastroek,\nZnach\ PostavitNaPodderzhku\ \=\ Neopredeleno,\nZnach\ VklyuchitVObedinenieObektyPoNerazreshennymSsylkam\ \=\ Neopredeleno,\nZnach\ Prinuditelno\ \=\ Lozh)\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/MergeCfg\ "\ +\ WrapInOuotationMarks(FaylKonfiguratsii));\nParametry\.Add("-Settings\ "\ +\ WrapInOuotationMarks(FaylNastroek));\nEsli\ PostavitNaPodderzhku\ \=\ Istina\ Togda\nParametry\.Add("-EnableSupport");\nInacheEsli\ PostavitNaPodderzhku\ \=\ Lozh\ Togda\nParametry\.Add("-DisableSupport");\nKonetsEsli;\nEsli\ VklyuchitVObedinenieObektyPoNerazreshennymSsylkam\ \=\ Istina\ Togda\nParametry\.Add("-IncludeObjectsByUnresolvedRefs");\nInacheEsli\ VklyuchitVObedinenieObektyPoNerazreshennymSsylkam\ \=\ Lozh\ Togda\nParametry\.Add("-ClearUnresolvedRefs");\nKonetsEsli;\nEsli\ Prinuditelno\ Togda\nParametry\.Add("-force");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ ObnovitKonfiguratsiyuBazyDannykh(PreduprezhdeniyaKakOshibki\ \=\ Lozh,\ AtServer\ \=\ Istina,\ DinamicheskoeObnovlenie\ \=\ Lozh)\ Export\nParametrySvyaziSBazoy\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametrySvyaziSBazoy\.Add("/UpdateDBCfg");\nEsli\ Dont\ DinamicheskoeObnovlenie\ Togda\nParametrySvyaziSBazoy\.Add("-Dynamic-");\nKonetsEsli;\nEsli\ PreduprezhdeniyaKakOshibki\ Togda\nParametrySvyaziSBazoy\.Add("-WarningsAsErrors");\nKonetsEsli;\nEsli\ AtServer\ Togda\nParametrySvyaziSBazoy\.Add("-Server");\nKonetsEsli;\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nProtsedura\ ObnovitKonfiguratsiyu(Znach\ KatalogVersii,\ Znach\ IspolzovatPolnyyDistributiv\ \=\ Lozh)\ Export\nParametryZapuska\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nEsli\ IspolzovatPolnyyDistributiv\ \=\ Neopredeleno\ Togda\nIspolzovatPolnyyDistributiv\ \=\ Dont\ KatalogSoderzhitFaylObnovleniya(KatalogVersii);\nKonetsEsli;\nEsli\ IspolzovatPolnyyDistributiv\ Togda\nFaylObnovleniya\ \=\ "1cv8\.cf";\nInache\nFaylObnovleniya\ \=\ "1cv8\.cfu";\nKonetsEsli;\nParametryZapuska\.Add("/UpdateCfg\ "\ +\ WrapInOuotationMarks(SavedToolsDataCatalogNameAtServer(KatalogVersii,\ FaylObnovleniya)));\nVypolnitKomandu(RunParameters);\nKonetsProtsedury\nProtsedura\ SnyatKonfiguratsiyuSPodderzhki(Znach\ Prinuditelno\ \=\ Lozh)\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/ManageCfgSupport\ -disableSupport");\nEsli\ Prinuditelno\ Togda\nParametry\.Add("-force");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ SkonvertirovatFaylKonfiguratsii(Znach\ FaylKonfiguratsii)\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/ConvertFiles\ """\ +\ FaylKonfiguratsii\ +\ """");\nVypolnitKomandu(Parameters);\nKonetsProtsedury.Description=Programmnyy Interface\nFunktsiya PoluchitVersiyuIzKhranilishcha(Znach StrokaSoedineniya, Znach PolzovatelKhranilishcha, Znach ParolKhranilishcha, Znach NomerVersii \= Neopredeleno) Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/ConfigurationRepositoryF """+StrokaSoedineniya+"""");\nParametry.Add("/ConfigurationRepositoryN """+PolzovatelKhranilishcha+"""");\nEsli Dont PustayaStroka(ParolKhranilishcha) Togda\nParametry.Add("/ConfigurationRepositoryP """+ParolKhranilishcha+"""");\nKonetsEsli;\nFaylRezultata \= SavedToolsDataCatalogNameAtServer(KatalogSborki(), "Source.cf");\nParametry.Add("/ConfigurationRepositoryDumpCfg """+FaylRezultata + """");\nEsli Dont PustayaStroka(NomerVersii) Togda\nParametry.Add("-v "+NomerVersii);\nKonetsEsli;\nVypolnitKomandu(Parameters);\nVozvrat FaylRezultata;\nKonetsFunktsii\nProtsedura SozdatFaylyPostavki(Znach PutFaylaPolnoyPostavki \="",\nznach PutFaylaPostavkiObnovleniya \= "",\nZnach DistributivyDlyaObnovleniya \= Neopredeleno, // Array Collection distributiva cf\nZnach PutFaylaSParametramiLitsenzirovaniya \= "") Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/CreateDistributionFiles ");\nEsli Dont ZnachenieZapolneno(PutFaylaPolnoyPostavki)\nI Dont ZnachenieZapolneno(PutFaylaPostavkiObnovleniya) Togda\nVyzvatIsklyuchenie "Dont pravilno zadany Parameters Procedures <" + "SozdatFaylyPostavki" +">";\nKonetsEsli;\nEsli ZnachenieZapolneno(PutFaylaPolnoyPostavki) Togda\nParametry.Add("-cffile "+WrapInOuotationMarks(PutFaylaPolnoyPostavki)+" ");\nKonetsEsli;\nEsli ZnachenieZapolneno(PutFaylaPostavkiObnovleniya)\nI Dont DistributivyDlyaObnovleniya \= Neopredeleno\nI DistributivyDlyaObnovleniya.Processed() > 0 Togda\nParametry.Add("-cfufile "+WrapInOuotationMarks(PutFaylaPostavkiObnovleniya)+" ");\nPodderzhivayutsya Only Files cf\nDlya kazhdogo DistributivObnovleniya From DistributivyDlyaObnovleniya Tsikl\nParametry.Add("-f "+WrapInOuotationMarks(DistributivObnovleniya)+" ");\nKonetsTsikla;\nKonetsEsli;\nEsli ZnachenieZapolneno(PutFaylaSParametramiLitsenzirovaniya) Togda\nParametry.Add("-digisign "+WrapInOuotationMarks(PutFaylaSParametramiLitsenzirovaniya)+" ");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura SozdatFaylovoeKhranilishcheKonfiguratsii(Znach PapkaKhranilishcha,\nZnach PolzovatelKhranilishcha,\nZnach ParolKhranilishcha \= "",\nznach PodklyuchitBazuKKhranilishchyu \= Lozh) Export\nObespechitKatalog(PapkaKhranilishcha);\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/ConfigurationRepositoryF """+PapkaKhranilishcha+"""");\nParametry.Add("/ConfigurationRepositoryN """+PolzovatelKhranilishcha+"""");\nEsli Dont PustayaStroka(ParolKhranilishcha) Togda\nParametry.Add("/ConfigurationRepositoryP """+ParolKhranilishcha+"""");\nKonetsEsli;\nParametry.Add("/ConfigurationRepositoryCreate ");\nParametry.Add("-AllowConfigurationChanges");\nParametry.Add("-ChangesAllowedRule ObjectNotSupported");\nParametry.Add("-ChangesNotRecommendedRule ObjectNotSupported");\nEsli PodklyuchitBazuKKhranilishchyu \= Lozh Togda\nParametry.Add("-NoBind");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura OtklyuchitsyaOtKhranilishcha() Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/ConfigurationRepositoryUnbindCfg -force ");\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura VygruzitKonfiguratsiyuVFayly(Znach KatalogVygruzki, Znach FormatVygruzki \= "") Export\nEsli Dont ZnachenieZapolneno(FormatVygruzki) Togda\nFormatVygruzki \= RezhimVygruzkiKonfiguratsii.Ierarkhicheskiy;\nKonetsEsli;\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add(StrShablon("/DumpConfigToFiles %1 -Format %2", WrapInOuotationMarks(KatalogVygruzki), FormatVygruzki));\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura ZagruzitKonfiguratsiyuIzFayla(Znach FaylKonfiguratsii, Znach ObnovitKonfiguratsiyuIB \= Lozh) Export\nVypolnyaem Import T Update Period dva Wizard, Config.S.\ninogda Update L IB To novoy Base prokhodit neudachno,\nesli Run dve Operation In One komande.\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/LoadCfg """ + FaylKonfiguratsii + """");\nVypolnitKomandu(Parameters);\nEsli ObnovitKonfiguratsiyuIB Togda\nObnovitKonfiguratsiyuBazyDannykh(Lozh, Istina);\nKonetsEsli;\nKonetsProtsedury\nProtsedura VygruzitKonfiguratsiyuVFayl(Znach FaylKonfiguratsii) Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/DumpCfg """ + FaylKonfiguratsii + """");\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nVypolnit Union Panel L C faylom (C ispolzovaniem Log Manager)\nOpisanie ITS\: http\://its.1c.ru/db/v83doc\#bookmark\:adm\:TI000000527\n\nParametry\:\nFaylKonfiguratsii - String - Name cf-Log C obedinyaemoy konfiguratsiey.\nFaylNastroek - String - Name Log C nastroykami obedineniya konfiguratsiy.\nPostavitNaPodderzhku - Boolean, Neopredeleno - Handlers Completion Rights L To podderzhku.\n\t\tNeopredeleno\: By Default Handlers Dont peredaetsya.\n\t\tIstina\: Group configuration stavitsya To podderzhku, If Has takaya vozmozhnost.\n\t\tLozh\: Group configuration Dont stavitsya To podderzhku, dazhe If Has takaya vozhzmozhnost.\nVklyuchitVObedinenieObektyPoNerazreshennymSsylkam - Boolean, Neopredeleno - Handlers nebkhodimosti New\n\t\tv Union Writing, Dont vklyuchennykh In Tasks obedinyaemykh T otsutstvuyushchikh In Main L.\n\t\tNeopredeleno\: By Default Handlers Dont peredaetsya.\n\t\tIstina\: vklyuchat Objects C nerazreshennymi ssylkami In Tasks obedinyaemykh.\n\t\tLozh\: Clear References To Objects C nerazreshennymi ssylkami.\nPrinuditelno - Boolean - Handlers prinuditelnogo Update.\n\t\tObnovlenie budet proizvoditsya In sluchae Setting\:\n\t\t\tpreduprezhdeniy On udalyaemykh Writing, To kotorye Has References In obektakh,\n\t\t\t\tne uchastvuyushchikh In obedinenii (takie Objects budut isklyucheny From obedineniya);\n\t\t\tpreduprezhdeniy D primenenii Manager.\n\t\tEsli Dont ukazan, to Union budet prervano In vysheukazannykh sluchayakh.\n\nProtsedura ObedinitKonfiguratsiyuSFaylom(Znach FaylKonfiguratsii,\nZnach FaylNastroek,\nZnach PostavitNaPodderzhku \= Neopredeleno,\nZnach VklyuchitVObedinenieObektyPoNerazreshennymSsylkam \= Neopredeleno,\nZnach Prinuditelno \= Lozh) Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/MergeCfg " + WrapInOuotationMarks(FaylKonfiguratsii));\nParametry.Add("-Settings " + WrapInOuotationMarks(FaylNastroek));\nEsli PostavitNaPodderzhku \= Istina Togda\nParametry.Add("-EnableSupport");\nInacheEsli PostavitNaPodderzhku \= Lozh Togda\nParametry.Add("-DisableSupport");\nKonetsEsli;\nEsli VklyuchitVObedinenieObektyPoNerazreshennymSsylkam \= Istina Togda\nParametry.Add("-IncludeObjectsByUnresolvedRefs");\nInacheEsli VklyuchitVObedinenieObektyPoNerazreshennymSsylkam \= Lozh Togda\nParametry.Add("-ClearUnresolvedRefs");\nKonetsEsli;\nEsli Prinuditelno Togda\nParametry.Add("-force");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura ObnovitKonfiguratsiyuBazyDannykh(PreduprezhdeniyaKakOshibki \= Lozh, AtServer \= Istina, DinamicheskoeObnovlenie \= Lozh) Export\nParametrySvyaziSBazoy \= StandartnyeParametryZapuskaKonfiguratora();\nParametrySvyaziSBazoy.Add("/UpdateDBCfg");\nEsli Dont DinamicheskoeObnovlenie Togda\nParametrySvyaziSBazoy.Add("-Dynamic-");\nKonetsEsli;\nEsli PreduprezhdeniyaKakOshibki Togda\nParametrySvyaziSBazoy.Add("-WarningsAsErrors");\nKonetsEsli;\nEsli AtServer Togda\nParametrySvyaziSBazoy.Add("-Server");\nKonetsEsli;\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nProtsedura ObnovitKonfiguratsiyu(Znach KatalogVersii, Znach IspolzovatPolnyyDistributiv \= Lozh) Export\nParametryZapuska \= StandartnyeParametryZapuskaKonfiguratora();\nEsli IspolzovatPolnyyDistributiv \= Neopredeleno Togda\nIspolzovatPolnyyDistributiv \= Dont KatalogSoderzhitFaylObnovleniya(KatalogVersii);\nKonetsEsli;\nEsli IspolzovatPolnyyDistributiv Togda\nFaylObnovleniya \= "1cv8.cf";\nInache\nFaylObnovleniya \= "1cv8.cfu";\nKonetsEsli;\nParametryZapuska.Add("/UpdateCfg " + WrapInOuotationMarks(SavedToolsDataCatalogNameAtServer(KatalogVersii, FaylObnovleniya)));\nVypolnitKomandu(RunParameters);\nKonetsProtsedury\nProtsedura SnyatKonfiguratsiyuSPodderzhki(Znach Prinuditelno \= Lozh) Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/ManageCfgSupport -disableSupport");\nEsli Prinuditelno Togda\nParametry.Add("-force");\nKonetsEsli;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura SkonvertirovatFaylKonfiguratsii(Znach FaylKonfiguratsii) Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/ConvertFiles """ + FaylKonfiguratsii + """");\nVypolnitKomandu(Parameters);\nKonetsProtsedury
Comment.Процедура\ ЗагрузитьИнформационнуюБазу(ПутьВыгрузкиИБ)\ Экспорт\nФайлВыгрузки\ \=\ New\ File(PutVygruzkiIB);\nOzhidaem\.Chto(FaylVygruzki\.Exists(),\ "File\ Table\ <"+PutVygruzkiIB+">\ Exists,\ A\ Is\ Dont\ tak")\.EtoIstina();\nParametryZapuska\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametryZapuska\.Add("/RestoreIB\ "\ +\ WrapInOuotationMarks(PutVygruzkiIB));\nVypolnitKomandu(RunParameters);\nKonetsProtsedury\nProtsedura\ VygruzitInformatsionnuyuBazu(PutVygruzkiIB)\ Export\nFayl\ \=\ New\ File(PutVygruzkiIB);\nKatalogVygruzkiIB\ \=\ File\.Path;\nObespechitKatalog(KatalogVygruzkiIB);\nParametryZapuska\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametryZapuska\.Add("/DumpIB\ "\ +\ WrapInOuotationMarks(PutVygruzkiIB));\nVypolnitKomandu(RunParameters);\nKonetsProtsedury.Description=Procedure ZagruzitInformatsionnuyuBazu(PutVygruzkiIB) Export\nFaylVygruzki \= New File(PutVygruzkiIB);\nOzhidaem.Chto(FaylVygruzki.Exists(), "File Table <"+PutVygruzkiIB+"> Exists, A Is Dont tak").EtoIstina();\nParametryZapuska \= StandartnyeParametryZapuskaKonfiguratora();\nParametryZapuska.Add("/RestoreIB " + WrapInOuotationMarks(PutVygruzkiIB));\nVypolnitKomandu(RunParameters);\nKonetsProtsedury\nProtsedura VygruzitInformatsionnuyuBazu(PutVygruzkiIB) Export\nFayl \= New File(PutVygruzkiIB);\nKatalogVygruzkiIB \= File.Path;\nObespechitKatalog(KatalogVygruzkiIB);\nParametryZapuska \= StandartnyeParametryZapuskaKonfiguratora();\nParametryZapuska.Add("/DumpIB " + WrapInOuotationMarks(PutVygruzkiIB));\nVypolnitKomandu(RunParameters);\nKonetsProtsedury
Comment.Процедура\ ОбеспечитьКаталог(Знач\ Каталог)\nФайл\ \=\ New\ File(Tech);\nEsli\ Dont\ File\.Exists()\ Togda\nSozdatKatalog(Tech);\nInacheEsli\ Dont\ File\.EtoKatalog()\ Togda\nVyzvatIsklyuchenie\ "Tech\ "\ +\ Tech\ +\ "\ Dont\ yavlyaetsya\ katalogom";\nKonetsEsli;\nKonetsProtsedury.Description=Procedure ProvideDirectory(Znach Tech)\nFayl \= New File(Tech);\nEsli Dont File.Exists() Togda\nSozdatKatalog(Tech);\nInacheEsli Dont File.EtoKatalog() Togda\nVyzvatIsklyuchenie "Tech " + Tech + " Dont yavlyaetsya katalogom";\nKonetsEsli;\nKonetsProtsedury
Comment.Функция\ ПолучитьПараметрыЗапуска()\ Экспорт\nВозврат\ СтандартныеПараметрыЗапускаКонфигуратора();\nКонецФункции\nПроцедура\ ВыполнитьРасширеннуюПроверкуКонфигуратора(Ключи)\ Экспорт\nПараметры\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/CheckConfig");\nDlya\ Kazhdogo\ StrokaKlyucha\ From\ Klyuchi\ Tsikl\nEsli\ StrokaKlyucha\.Value\ \=\ Istina\ Togda\nParametry\.Add(StrokaKlyucha\.Key);\nKonetsEsli;\nKonetsTsikla;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ VypolnitSintaksicheskiyKontrol(\nZnach\ TonkiyKlient\ \=\ Istina,\nZnach\ VebKlient\ \=\ Istina,\nZnach\ Files on server\ \=\ Istina,\nZnach\ VneshneeSoedinenie\ \=\ Istina,\nZnach\ TolstyyKlientObychnoePrilozhenie\ \=\ Istina)\ Export\nParametry\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametry\.Add("/CheckConfig");\nDobavitFlagProverki(Parameters,\ TonkiyKlient,\ "-ThinClient");\nDobavitFlagProverki(Parameters,\ VebKlient,\ "-WebClient");\nDobavitFlagProverki(Parameters,\ Files on server,\ "-Server");\nDobavitFlagProverki(Parameters,\ VneshneeSoedinenie,\ "-ExternalConnection");\nDobavitFlagProverki(Parameters,\ TolstyyKlientObychnoePrilozhenie,\ "-ThickClientOrdinaryApplication");\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura\ ZapustitVRezhimePredpriyatiya(Znach\ KlyuchZapuska\ \=\ "",\ Znach\ UpravlyaemyyRezhim\ \=\ Neopredeleno,\ Znach\ DopolnitelnyeKlyuchi\ \=\ Neopredeleno)\ Export\nParametrySvyaziSBazoy\ \=\ PoluchitParametryZapuska();\nParametrySvyaziSBazoy[0]\ \=\ "ENTERPRISE";\nEsli\ Dont\ PustayaStroka(KlyuchZapuska)\ Togda\nParametrySvyaziSBazoy\.Add("/C"+KlyuchZapuska);\nKonetsEsli;\nEsli\ UpravlyaemyyRezhim\ \=\ Istina\ Togda\nParametrySvyaziSBazoy\.Insert(2,\ "/RunModeManagedApplication");\nInacheEsli\ UpravlyaemyyRezhim\ \=\ Lozh\ Togda\nParametrySvyaziSBazoy\.Insert(2,\ "/RunModeOrdinaryApplication");\nKonetsEsli;\nEsli\ DopolnitelnyeKlyuchi\ <>\ Neopredeleno\ Togda\nParametrySvyaziSBazoy\.Add(DopolnitelnyeKlyuchi);\nKonetsEsli;\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nProtsedura\ DobavitFlagProverki(Znach\ Parameters,\ Znach\ FlagProverki,\ Znach\ ImyaFlaga)\nEsli\ FlagProverki\ Togda\nParametry\.Add(ImyaFlaga);\nKonetsEsli;\nKonetsProtsedury\nFunktsiya\ KatalogSoderzhitFaylObnovleniya(Znach\ KatalogVersii)\nFaylObnovleniya\ \=\ New\ File(SavedToolsDataCatalogNameAtServer(KatalogVersii,\ "1cv8\.cfu"));\nVozvrat\ FaylObnovleniya\.Exists();\nKonetsFunktsii.Description=Function PoluchitParametryZapuska() Export\nVozvrat StandartnyeParametryZapuskaKonfiguratora();\nKonetsFunktsii\nProtsedura VypolnitRasshirennuyuProverkuKonfiguratora(Klyuchi) Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/CheckConfig");\nDlya Kazhdogo StrokaKlyucha From Klyuchi Tsikl\nEsli StrokaKlyucha.Value \= Istina Togda\nParametry.Add(StrokaKlyucha.Key);\nKonetsEsli;\nKonetsTsikla;\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura VypolnitSintaksicheskiyKontrol(\nZnach TonkiyKlient \= Istina,\nZnach VebKlient \= Istina,\nZnach Files on server \= Istina,\nZnach VneshneeSoedinenie \= Istina,\nZnach TolstyyKlientObychnoePrilozhenie \= Istina) Export\nParametry \= StandartnyeParametryZapuskaKonfiguratora();\nParametry.Add("/CheckConfig");\nDobavitFlagProverki(Parameters, TonkiyKlient, "-ThinClient");\nDobavitFlagProverki(Parameters, VebKlient, "-WebClient");\nDobavitFlagProverki(Parameters, Files on server, "-Server");\nDobavitFlagProverki(Parameters, VneshneeSoedinenie, "-ExternalConnection");\nDobavitFlagProverki(Parameters, TolstyyKlientObychnoePrilozhenie, "-ThickClientOrdinaryApplication");\nVypolnitKomandu(Parameters);\nKonetsProtsedury\nProtsedura ZapustitVRezhimePredpriyatiya(Znach KlyuchZapuska \= "", Znach UpravlyaemyyRezhim \= Neopredeleno, Znach DopolnitelnyeKlyuchi \= Neopredeleno) Export\nParametrySvyaziSBazoy \= PoluchitParametryZapuska();\nParametrySvyaziSBazoy[0] \= "ENTERPRISE";\nEsli Dont PustayaStroka(KlyuchZapuska) Togda\nParametrySvyaziSBazoy.Add("/C"+KlyuchZapuska);\nKonetsEsli;\nEsli UpravlyaemyyRezhim \= Istina Togda\nParametrySvyaziSBazoy.Insert(2, "/RunModeManagedApplication");\nInacheEsli UpravlyaemyyRezhim \= Lozh Togda\nParametrySvyaziSBazoy.Insert(2, "/RunModeOrdinaryApplication");\nKonetsEsli;\nEsli DopolnitelnyeKlyuchi <> Neopredeleno Togda\nParametrySvyaziSBazoy.Add(DopolnitelnyeKlyuchi);\nKonetsEsli;\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nProtsedura DobavitFlagProverki(Znach Parameters, Znach FlagProverki, Znach ImyaFlaga)\nEsli FlagProverki Togda\nParametry.Add(ImyaFlaga);\nKonetsEsli;\nKonetsProtsedury\nFunktsiya KatalogSoderzhitFaylObnovleniya(Znach KatalogVersii)\nFaylObnovleniya \= New File(SavedToolsDataCatalogNameAtServer(KatalogVersii, "1cv8.cfu"));\nVozvrat FaylObnovleniya.Exists();\nKonetsFunktsii
Comment.Функция\ ПрочитатьФайлИнформации()\nТекст\ \=\ "";\nFayl\ \=\ New\ File(FaylInformatsii());\nEsli\ File\.Exists()\ Togda\nChtenie\ \=\ New\ ChtenieTeksta(File\.PolnoeImya);\nTekst\ \=\ Read\.Read();\nChtenie\.Close();\nInache\nTekst\ \=\ "Information\ On\ O\ Objects";\nKonetsEsli;\nLog\.Debug("File\ Information\:\n|"+Text);\nVozvrat\ Text;\nKonetsFunktsii\nProtsedura\ UstanovitVyvod(Znach\ Message)\nmVyvodKomandy\ \=\ Message;\nKonetsProtsedury.Description=Function ProchitatFaylInformatsii()\nTekst \= "";\nFayl \= New File(FaylInformatsii());\nEsli File.Exists() Togda\nChtenie \= New ChtenieTeksta(File.PolnoeImya);\nTekst \= Read.Read();\nChtenie.Close();\nInache\nTekst \= "Information On O Objects";\nKonetsEsli;\nLog.Debug("File Information\:\n|"+Text);\nVozvrat Text;\nKonetsFunktsii\nProtsedura UstanovitVyvod(Znach Message)\nmVyvodKomandy \= Message;\nKonetsProtsedury
Comment.Функция\ ХранилищеКонфигурацииСуществует(Знач\ ПапкаХранилища)\ Экспорт\nФайлБазы\ \=\ New\ File(SavedToolsDataCatalogNameAtServer(PapkaKhranilishcha,\ "1cv8ddb\.1CD"));\nVozvrat\ FaylBazy\.Exists();\nKonetsFunktsii\nFunktsiya\ SplitStringIntoSubstringsArray(IskhodnayaStroka,\ Separator)\nMassivPodstrok\ \=\ New\ Array;\nOstatokStroki\ \=\ IskhodnayaStroka;\nPoz\ \=\ -1;\nPoka\ Poz\ <>\ 0\ Tsikl\nPoz\ \=\ Find(OstatokStroki,\ Separator);\nEsli\ Poz\ >\ 0\ Togda\nPodstroka\ \=\ Lev(OstatokStroki,\ Poz-1);\nOstatokStroki\ \=\ Sred(OstatokStroki,\ Poz+1);\nInache\nPodstroka\ \=\ OstatokStroki;\nKonetsEsli;\nMassivPodstrok\.Add(Substring);\nKonetsTsikla;\nVozvrat\ MassivPodstrok;\nKonetsFunktsii\nFunktsiya\ WrapInOuotationMarks(Znach\ String);\nEsli\ Lev(String,\ 1)\ \=\ """"\ T\ Rights(String,\ 1)\ \=\ """"\ Togda\nVozvrat\ String;\nInache\nVozvrat\ """"\ +\ String\ +\ """";\nKonetsEsli;\nKonetsFunktsii\nProtsedura\ Init()\nSistemnayaInformatsiya\ \=\ New\ SistemnayaInformatsiya;\nEtoWindows\ \=\ Find(NReg(SistemnayaInformatsiya\.VersiyaOS),\ "Windows")\ >\ 0;\nmKontekstKomandy\ \=\ New\ Structure;\nmKontekstKomandy\.Insert("KlyuchSoedineniyaSBazoy",\ "");\nmKontekstKomandy\.Insert("ImyaPolzovatelya",\ "");\nmKontekstKomandy\.Insert("Password",\ "");\nmKontekstKomandy\.Insert("KlyuchRazresheniyaZapuska",\ "");\nmKontekstKomandy\.Insert("KodYazyka",\ "");\nmKontekstKomandy\.Insert("KodYazykaSeansa",\ "");\nPutKPlatforme1S(PoluchitPutKVersiiPlatformy("8\.3"));\nKonetsProtsedury\nProtsedura\ PoluchitIzmeneniyaKonfiguratsiiBazyDannykhIzKhranilishcha(Znach\ StrokaSoedineniya,\ Znach\ PolzovatelKhranilishcha,\ Znach\ ParolKhranilishcha\="")\ Export\nParametrySvyaziSBazoy\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryF\ """+StrokaSoedineniya+"""");\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryN\ """+PolzovatelKhranilishcha+"""");\nEsli\ Dont\ PustayaStroka(ParolKhranilishcha)\ Togda\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryP\ """+ParolKhranilishcha+"""");\nKonetsEsli;\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryUpdateCfg");\nParametrySvyaziSBazoy\.Add("-force");\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nProtsedura\ ObnovitKonfiguratsiyuBazyDannykhIzKhranilishcha(StrokaSoedineniya,\ PolzovatelKhranilishcha,\ ParolKhranilishcha\="")\ Export\nParametrySvyaziSBazoy\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryF\ """+StrokaSoedineniya+"""");\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryN\ """+PolzovatelKhranilishcha+"""");\nEsli\ Dont\ PustayaStroka(ParolKhranilishcha)\ Togda\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryP\ """+ParolKhranilishcha+"""");\nKonetsEsli;\nParametrySvyaziSBazoy\.Add("/ConfigurationRepositoryUpdateCfg");\nParametrySvyaziSBazoy\.Add("-force");\nParametrySvyaziSBazoy\.Add("/UpdateDBCfg");\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nFunktsiya\ VariantObrabotkiNesushchestvuyushchikhSsylok()\ Export\nVarianty\ \=\ New\ Structure;\nVarianty\.Insert("SozdavatObekty",\ 1);\nVarianty\.Insert("OchishchatObekty",\ \ \ 2);\nVarianty\.Insert("NeIzmenyat",\ \ \ \ \ \ \ 3);\nVozvrat\ New\ FiksirovannayaStruktura(D);\nKonetsFunktsii\ //\ ImyaFunktsii()\nFunktsiya\ VariantObrabotkiChastichnoyPoteriDannykh()\ Export\nVarianty\ \=\ New\ Structure;\nVarianty\.Insert("SozdavatObekty",\ 1);\nVarianty\.Insert("UdalyatObekty",\ \ \ 2);\nVozvrat\ New\ FiksirovannayaStruktura(D);\nKonetsFunktsii\ //\ ImyaFunktsii()\nStruktura\ C\ vozmozhnymi\ Parameters\ Data\ TiI\.\nPo\ Default\ vklyucheny\ All\ Page,\ Objects\ By\ By\ Type\ provedeniya\ testirovaniya\.\n\nVariantObrabotkiNesushchestvuyushchikhSsylok\:\n-\ Create\ Objects\ (By\ Default)\n-\ Clear\ Objects\n-\ Dont\ izmenyat\ On\ chastichnoy\ potere\ Writing\n\nVariantObrabotkiChastichnoyPoteriDannykh\:\n-\ Create\ Objects\ (By\ Default)\n-\ Delete\ Objects\n\nFunktsiya\ PoluchitOptsiiTiI()\ Export\nVariantyObrabotkiNesushchestvuyushchikhSsylok\ \=\ VariantObrabotkiNesushchestvuyushchikhSsylok();\nVariantyObrabotkiChastichnoyPoteriDannykh\ \=\ VariantObrabotkiChastichnoyPoteriDannykh();\nStrukturaOptsiiTiI\ \=\ New\ Structure;\nStrukturaOptsiiTiI\.Insert("TolkoTestirovanie",\ Istina);\nStrukturaOptsiiTiI\.Insert("Reindeksatsiya",\ Istina);\nStrukturaOptsiiTiI\.Insert("LogicheskayaTselostnost",\ Istina);\nStrukturaOptsiiTiI\.Insert("LogicheskayaISsylochnayaTselostnost",\ Istina);\nStrukturaOptsiiTiI\.Insert("PereschetItogov",\ Istina);\nStrukturaOptsiiTiI\.Insert("SzhatieTablits",\ Istina);\nStrukturaOptsiiTiI\.Insert("Restrukturizatsiya",\ Istina);\nStrukturaOptsiiTiI\.Insert("VariantObrabotkiNesushchestvuyushchikhSsylok",\ VariantyObrabotkiNesushchestvuyushchikhSsylok\.SozdavatObekty);\nStrukturaOptsiiTiI\.Insert("VariantObrabotkiChastichnoyPoteriDannykh",\ VariantyObrabotkiChastichnoyPoteriDannykh\.SozdavatObekty);\nStrukturaOptsiiTiI\.Insert("ProdolzhitTiISTochkiPreryvaniya",\ Lozh);\nStrukturaOptsiiTiI\.Insert("MaksVremyaTestirovaniya",\ "");\nVozvrat\ StrukturaOptsiiTiI;\nKonetsFunktsii\ //\ PoluchitOptsiiTiI()\nZapustit\ testirovanie\ T\ ispravlenie\ C\ ukazannymi\ optsiyami\.\nFunktsiya\ PoluchitOptsiiTiI\ vernet\ Conversion\ so\ vsemi\ optsiyami\.\nPo\ Default\ All\ Page\ vklyucheny\.\ Otklyuchayutsya\ pereopredeleniem\ Form\.\n\nParametry\:\nParametry\ -\ Structure\ -\ Structure\ C\ optsiyami\ Data\.\ If\ Parameter\ Dont\ zapolnen\ -\ delaetsya\ Full\ Hierarchy\.\n\nPrimer\:\nStrokaSoedineniya\ \=\ \ "/Fc\:\\Work\\db\\fin\\";\nUpravlenieKonfiguratorom\ \=\ New\ UpravlenieKonfiguratorom();\nUpravlenieKonfiguratorom\.UstanovitKontekst(StrokaSoedineniya,\ "",\ "");\nPolnaya\ Hierarchy\nUpravlenieKonfiguratorom\.ZapustitTestirovanieIIspravlenie();\n\nOptsiiTiI\ \=\ UpravlenieKonfiguratorom\.PoluchitOptsiiTiI();\nOtklyuchit\ Checking\ logicheskoy\ T\ ssylochnoy\ tselostnosti\nOptsiiTiI\.Insert("LogicheskayaISsylochnayaTselostnost",\ Lozh);\nUpravlenieKonfiguratorom\.ZapustitTestirovanieIIspravlenie(OptsiiTiI);\n\nProtsedura\ ZapustitTestirovanieIIspravlenie(Parameters\ \=\ Neopredeleno)\ Export\nParametrySvyaziSBazoy\ \=\ StandartnyeParametryZapuskaKonfiguratora();\nVariantyObrabotkiNesushchestvuyushchikhSsylok\ \=\ VariantObrabotkiNesushchestvuyushchikhSsylok();\nVariantyObrabotkiChastichnoyPoteriDannykh\ \=\ VariantObrabotkiChastichnoyPoteriDannykh();\nEsli\ Parameters\ \=\ Neopredeleno\ Togda\nParametry\ \=\ PoluchitOptsiiTiI();\nKonetsEsli;\nStrokaOptsiy\ \=\ "/IBCheckAndRepair";\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.TolkoTestirovanie,\ "\ -TestOnly",\ "");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.Reindeksatsiya,\ "\ -ReIndex",\ "");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.LogicheskayaTselostnost,\ "\ -LogIntegrity",\ "");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.LogicheskayaISsylochnayaTselostnost,\ "\ -LogAndRefsIntegrity",\ "");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.PereschetItogov,\ "\ -RecalcTotals",\ "");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.SzhatieTablits,\ "\ -IBCompression",\ "");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.Restrukturizatsiya,\ "\ -Rebuild",\ "");\nBityeSsylki\ \=\ Parameters\.VariantObrabotkiNesushchestvuyushchikhSsylok;\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(BityeSsylki\ \=\ VariantyObrabotkiNesushchestvuyushchikhSsylok\.SozdavatObekty,\ "\ -BadRefCreate",\ ?(BityeSsylki\ \=\ VariantyObrabotkiNesushchestvuyushchikhSsylok\.OchishchatObekty,\ "\ -BadRefClear",\ "\ -BadRefNone"));\nChastichnayaPoterya\ \=\ Parameters\.VariantObrabotkiChastichnoyPoteriDannykh;\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(ChastichnayaPoterya\ \=\ VariantyObrabotkiChastichnoyPoteriDannykh\.SozdavatObekty,\ "\ -BadDataCreate",\ "\ -BadDataDelete");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.ProdolzhitTiISTochkiPreryvaniya,\ "\ -UseStartPoint",\ "");\nStrokaOptsiy\ \=\ StrokaOptsiy\ +\ ?(Parameters\.MaksVremyaTestirovaniya\ \=\ "",\ "","\ -TimeLimit\:"\ +\ Parameters\.MaksVremyaTestirovaniya);\nParametrySvyaziSBazoy\.Add(StrokaOptsiy);\nLog\.Debug("Parameters\ Data\ TiI\:\ "\ +\ StrokaOptsiy);\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\ //\ ImyaProtsedury()\n\nInitsializatsiya\nInitsializatsiya();.Description=Function KhranilishcheKonfiguratsiiSushchestvuet(Znach PapkaKhranilishcha) Export\nFaylBazy \= New File(SavedToolsDataCatalogNameAtServer(PapkaKhranilishcha, "1cv8ddb.1CD"));\nVozvrat FaylBazy.Exists();\nKonetsFunktsii\nFunktsiya SplitStringIntoSubstringsArray(IskhodnayaStroka, Separator)\nMassivPodstrok \= New Array;\nOstatokStroki \= IskhodnayaStroka;\nPoz \= -1;\nPoka Poz <> 0 Tsikl\nPoz \= Find(OstatokStroki, Separator);\nEsli Poz > 0 Togda\nPodstroka \= Lev(OstatokStroki, Poz-1);\nOstatokStroki \= Sred(OstatokStroki, Poz+1);\nInache\nPodstroka \= OstatokStroki;\nKonetsEsli;\nMassivPodstrok.Add(Substring);\nKonetsTsikla;\nVozvrat MassivPodstrok;\nKonetsFunktsii\nFunktsiya WrapInOuotationMarks(Znach String);\nEsli Lev(String, 1) \= """" T Rights(String, 1) \= """" Togda\nVozvrat String;\nInache\nVozvrat """" + String + """";\nKonetsEsli;\nKonetsFunktsii\nProtsedura Init()\nSistemnayaInformatsiya \= New SistemnayaInformatsiya;\nEtoWindows \= Find(NReg(SistemnayaInformatsiya.VersiyaOS), "Windows") > 0;\nmKontekstKomandy \= New Structure;\nmKontekstKomandy.Insert("KlyuchSoedineniyaSBazoy", "");\nmKontekstKomandy.Insert("ImyaPolzovatelya", "");\nmKontekstKomandy.Insert("Password", "");\nmKontekstKomandy.Insert("KlyuchRazresheniyaZapuska", "");\nmKontekstKomandy.Insert("KodYazyka", "");\nmKontekstKomandy.Insert("KodYazykaSeansa", "");\nPutKPlatforme1S(PoluchitPutKVersiiPlatformy("8.3"));\nKonetsProtsedury\nProtsedura PoluchitIzmeneniyaKonfiguratsiiBazyDannykhIzKhranilishcha(Znach StrokaSoedineniya, Znach PolzovatelKhranilishcha, Znach ParolKhranilishcha\="") Export\nParametrySvyaziSBazoy \= StandartnyeParametryZapuskaKonfiguratora();\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryF """+StrokaSoedineniya+"""");\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryN """+PolzovatelKhranilishcha+"""");\nEsli Dont PustayaStroka(ParolKhranilishcha) Togda\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryP """+ParolKhranilishcha+"""");\nKonetsEsli;\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryUpdateCfg");\nParametrySvyaziSBazoy.Add("-force");\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nProtsedura ObnovitKonfiguratsiyuBazyDannykhIzKhranilishcha(StrokaSoedineniya, PolzovatelKhranilishcha, ParolKhranilishcha\="") Export\nParametrySvyaziSBazoy \= StandartnyeParametryZapuskaKonfiguratora();\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryF """+StrokaSoedineniya+"""");\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryN """+PolzovatelKhranilishcha+"""");\nEsli Dont PustayaStroka(ParolKhranilishcha) Togda\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryP """+ParolKhranilishcha+"""");\nKonetsEsli;\nParametrySvyaziSBazoy.Add("/ConfigurationRepositoryUpdateCfg");\nParametrySvyaziSBazoy.Add("-force");\nParametrySvyaziSBazoy.Add("/UpdateDBCfg");\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury\nFunktsiya VariantObrabotkiNesushchestvuyushchikhSsylok() Export\nVarianty \= New Structure;\nVarianty.Insert("SozdavatObekty", 1);\nVarianty.Insert("OchishchatObekty",   2);\nVarianty.Insert("NeIzmenyat",       3);\nVozvrat New FiksirovannayaStruktura(D);\nKonetsFunktsii // ImyaFunktsii()\nFunktsiya VariantObrabotkiChastichnoyPoteriDannykh() Export\nVarianty \= New Structure;\nVarianty.Insert("SozdavatObekty", 1);\nVarianty.Insert("UdalyatObekty",   2);\nVozvrat New FiksirovannayaStruktura(D);\nKonetsFunktsii // ImyaFunktsii()\nStruktura C vozmozhnymi Parameters Data TiI.\nPo Default vklyucheny All Page, Objects By By Type provedeniya testirovaniya.\n\nVariantObrabotkiNesushchestvuyushchikhSsylok\:\n- Create Objects (By Default)\n- Clear Objects\n- Dont izmenyat On chastichnoy potere Writing\n\nVariantObrabotkiChastichnoyPoteriDannykh\:\n- Create Objects (By Default)\n- Delete Objects\n\nFunktsiya PoluchitOptsiiTiI() Export\nVariantyObrabotkiNesushchestvuyushchikhSsylok \= VariantObrabotkiNesushchestvuyushchikhSsylok();\nVariantyObrabotkiChastichnoyPoteriDannykh \= VariantObrabotkiChastichnoyPoteriDannykh();\nStrukturaOptsiiTiI \= New Structure;\nStrukturaOptsiiTiI.Insert("TolkoTestirovanie", Istina);\nStrukturaOptsiiTiI.Insert("Reindeksatsiya", Istina);\nStrukturaOptsiiTiI.Insert("LogicheskayaTselostnost", Istina);\nStrukturaOptsiiTiI.Insert("LogicheskayaISsylochnayaTselostnost", Istina);\nStrukturaOptsiiTiI.Insert("PereschetItogov", Istina);\nStrukturaOptsiiTiI.Insert("SzhatieTablits", Istina);\nStrukturaOptsiiTiI.Insert("Restrukturizatsiya", Istina);\nStrukturaOptsiiTiI.Insert("VariantObrabotkiNesushchestvuyushchikhSsylok", VariantyObrabotkiNesushchestvuyushchikhSsylok.SozdavatObekty);\nStrukturaOptsiiTiI.Insert("VariantObrabotkiChastichnoyPoteriDannykh", VariantyObrabotkiChastichnoyPoteriDannykh.SozdavatObekty);\nStrukturaOptsiiTiI.Insert("ProdolzhitTiISTochkiPreryvaniya", Lozh);\nStrukturaOptsiiTiI.Insert("MaksVremyaTestirovaniya", "");\nVozvrat StrukturaOptsiiTiI;\nKonetsFunktsii // PoluchitOptsiiTiI()\nZapustit testirovanie T ispravlenie C ukazannymi optsiyami.\nFunktsiya PoluchitOptsiiTiI vernet Conversion so vsemi optsiyami.\nPo Default All Page vklyucheny. Otklyuchayutsya pereopredeleniem Form.\n\nParametry\:\nParametry - Structure - Structure C optsiyami Data. If Parameter Dont zapolnen - delaetsya Full Hierarchy.\n\nPrimer\:\nStrokaSoedineniya \=  "/Fc\:\\Work\\db\\fin\\";\nUpravlenieKonfiguratorom \= New UpravlenieKonfiguratorom();\nUpravlenieKonfiguratorom.UstanovitKontekst(StrokaSoedineniya, "", "");\nPolnaya Hierarchy\nUpravlenieKonfiguratorom.ZapustitTestirovanieIIspravlenie();\n\nOptsiiTiI \= UpravlenieKonfiguratorom.PoluchitOptsiiTiI();\nOtklyuchit Checking logicheskoy T ssylochnoy tselostnosti\nOptsiiTiI.Insert("LogicheskayaISsylochnayaTselostnost", Lozh);\nUpravlenieKonfiguratorom.ZapustitTestirovanieIIspravlenie(OptsiiTiI);\n\nProtsedura ZapustitTestirovanieIIspravlenie(Parameters \= Neopredeleno) Export\nParametrySvyaziSBazoy \= StandartnyeParametryZapuskaKonfiguratora();\nVariantyObrabotkiNesushchestvuyushchikhSsylok \= VariantObrabotkiNesushchestvuyushchikhSsylok();\nVariantyObrabotkiChastichnoyPoteriDannykh \= VariantObrabotkiChastichnoyPoteriDannykh();\nEsli Parameters \= Neopredeleno Togda\nParametry \= PoluchitOptsiiTiI();\nKonetsEsli;\nStrokaOptsiy \= "/IBCheckAndRepair";\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.TolkoTestirovanie, " -TestOnly", "");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.Reindeksatsiya, " -ReIndex", "");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.LogicheskayaTselostnost, " -LogIntegrity", "");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.LogicheskayaISsylochnayaTselostnost, " -LogAndRefsIntegrity", "");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.PereschetItogov, " -RecalcTotals", "");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.SzhatieTablits, " -IBCompression", "");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.Restrukturizatsiya, " -Rebuild", "");\nBityeSsylki \= Parameters.VariantObrabotkiNesushchestvuyushchikhSsylok;\nStrokaOptsiy \= StrokaOptsiy + ?(BityeSsylki \= VariantyObrabotkiNesushchestvuyushchikhSsylok.SozdavatObekty, " -BadRefCreate", ?(BityeSsylki \= VariantyObrabotkiNesushchestvuyushchikhSsylok.OchishchatObekty, " -BadRefClear", " -BadRefNone"));\nChastichnayaPoterya \= Parameters.VariantObrabotkiChastichnoyPoteriDannykh;\nStrokaOptsiy \= StrokaOptsiy + ?(ChastichnayaPoterya \= VariantyObrabotkiChastichnoyPoteriDannykh.SozdavatObekty, " -BadDataCreate", " -BadDataDelete");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.ProdolzhitTiISTochkiPreryvaniya, " -UseStartPoint", "");\nStrokaOptsiy \= StrokaOptsiy + ?(Parameters.MaksVremyaTestirovaniya \= "", ""," -TimeLimit\:" + Parameters.MaksVremyaTestirovaniya);\nParametrySvyaziSBazoy.Add(StrokaOptsiy);\nLog.Debug("Parameters Data TiI\: " + StrokaOptsiy);\nVypolnitKomandu(ParametrySvyaziSBazoy);\nKonetsProtsedury // ImyaProtsedury()\n\nInitsializatsiya\nInitsializatsiya();
