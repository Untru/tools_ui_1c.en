Method.ВывестиФоновые.Comment.Если\ ТипЗнч(Отбор)\ \=\ Type("Structure")\ T\ Filter\.Property("ReglamentnoeZadanie",\ ReglamentnoeZadanieOtbora)\ Togda\nTekOtbor\ \=\ GetBackgroundJobsFilter();\nTekOtbor\.Delete("ReglamentnoeZadanie");\nOtborPoMetodu\ \=\ New\ Structure("Method",\ ReglamentnoeZadanieOtbora\.Metadata\.ImyaMetoda);\nOtborPoKlyuchu\ \=\ New\ Structure("Key",\ ReglamentnoeZadanieOtbora\.Metadata\.Key);\nEsli\ SpisokReglamentnykhZadaniy\.FillDCSForDebug(OtborPoMetodu)\.Processed()\ \=\ 1\ Togda\npo\ Name\ metoda\ -\ If\ C\ takim\ imenem\ metoda\ Only\ Single\ ekzemplyar\nTekOtbor\.Insert("ImyaMetoda",\ ReglamentnoeZadanieOtbora\.Metadata\.ImyaMetoda);\nInacheEsli\ SpisokReglamentnykhZadaniy\.FillDCSForDebug(OtborPoKlyuchu)\.Processed()\ \=\ 1\ Togda\npo\ Name\ String\ -\ If\ C\ takim\ klyuchom\ Only\ Single\ ekzemplyar\nTekOtbor\.Insert("Key",\ ReglamentnoeZadanieOtbora\.Metadata\.Key);\nInache\npo\ Name\ Filter\ Dialog\nTekOtbor\.Insert("Description",\ "Run\ Manually\:\ "\ +\ ReglamentnoeZadanieOtbora\.Metadata\.Sinonim);\nKonetsEsli;\nPopytka\nFonovyeRuchnye\ \=\ BackgroundJobs\.PoluchitFonovyeZadaniya(TekOtbor);\nIsklyuchenie\nTekstOshibki\ \=\ OpisanieOshibki();\nSoobshchitPolzovatelyu(TekstOshibki);\nVozvrat;\nKonetsPopytki;\nDlya\ Kazhdogo\ FonovoeRuchnoe\ From\ FonovyeRuchnye\ Tsikl\nEsli\ Background\.Find(FonovoeRuchnoe)\ \=\ Neopredeleno\ Togda\nFonovye\.Add(FonovoeRuchnoe);\nKonetsEsli;\nKonetsTsikla;\nKonetsEsli;.Description=If TipZnch(Filter) \= Type("Structure") T Filter.Property("ReglamentnoeZadanie", ReglamentnoeZadanieOtbora) Togda\nTekOtbor \= GetBackgroundJobsFilter();\nTekOtbor.Delete("ReglamentnoeZadanie");\nOtborPoMetodu \= New Structure("Method", ReglamentnoeZadanieOtbora.Metadata.ImyaMetoda);\nOtborPoKlyuchu \= New Structure("Key", ReglamentnoeZadanieOtbora.Metadata.Key);\nEsli SpisokReglamentnykhZadaniy.FillDCSForDebug(OtborPoMetodu).Processed() \= 1 Togda\npo Name metoda - If C takim imenem metoda Only Single ekzemplyar\nTekOtbor.Insert("ImyaMetoda", ReglamentnoeZadanieOtbora.Metadata.ImyaMetoda);\nInacheEsli SpisokReglamentnykhZadaniy.FillDCSForDebug(OtborPoKlyuchu).Processed() \= 1 Togda\npo Name String - If C takim klyuchom Only Single ekzemplyar\nTekOtbor.Insert("Key", ReglamentnoeZadanieOtbora.Metadata.Key);\nInache\npo Name Filter Dialog\nTekOtbor.Insert("Description", "Run Manually\: " + ReglamentnoeZadanieOtbora.Metadata.Sinonim);\nKonetsEsli;\nPopytka\nFonovyeRuchnye \= BackgroundJobs.PoluchitFonovyeZadaniya(TekOtbor);\nIsklyuchenie\nTekstOshibki \= OpisanieOshibki();\nSoobshchitPolzovatelyu(TekstOshibki);\nVozvrat;\nKonetsPopytki;\nDlya Kazhdogo FonovoeRuchnoe From FonovyeRuchnye Tsikl\nEsli Background.Find(FonovoeRuchnoe) \= Neopredeleno Togda\nFonovye.Add(FonovoeRuchnoe);\nKonetsEsli;\nKonetsTsikla;\nKonetsEsli;
