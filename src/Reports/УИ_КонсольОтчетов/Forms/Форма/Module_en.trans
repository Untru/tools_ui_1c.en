Method.СформироватьНаСервереВТабличныйДокумент.Comment.ИначеЕсли\ Элемент\.s\ \=\ 1\ Togda\nVariant\ Builder\.\nSkhemaKomponovkiDannykh\ \=\ PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov\.NaytiPoIdentifikatoru(Items\.DerevoOtchetov\.TekushchayaStroka))\.Data);\nKomponovshchikMaketa\ \=\ New\ KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh\ \=\ KomponovshchikMaketa\.Execute(DataCompositionSchema,\ Report\.KomponovshchikNastroek\.Settings,\ DannyeRasshifrovkiObekt);\nAdresSkhemyIspolnennogoOtcheta\ \=\ PomestitVoVremennoeKhranilishche(DataCompositionSchema,\ ?(AdresSkhemyIspolnennogoOtcheta\ <>\ "",\ AdresSkhemyIspolnennogoOtcheta,\ UUIDString));\nVyvestiMaketKomponovkiDannykhVTablichnyyDokument(MaketKomponovkiDannykh,\ DannyeRasshifrovkiObekt);\nOtobrazitPanelRezultatov();\nInacheEsli\ Item\.TipStroki\ \=\ 2\ Togda\nNastroyki\ Builder\.\nSkhemaKomponovkiDannykh\ \=\ PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov\.NaytiPoIdentifikatoru(Items\.DerevoOtchetov\.TekushchayaStroka))\.Data);\nKomponovshchikMaketa\ \=\ New\ KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh\ \=\ KomponovshchikMaketa\.Execute(DataCompositionSchema,\ Report\.KomponovshchikNastroek\.GetSettings(),\ DannyeRasshifrovkiObekt);\nAdresSkhemyIspolnennogoOtcheta\ \=\ PomestitVoVremennoeKhranilishche(DataCompositionSchema,\ ?(AdresSkhemyIspolnennogoOtcheta\ <>\ "",\ AdresSkhemyIspolnennogoOtcheta,\ UUIDString));\nVyvestiMaketKomponovkiDannykhVTablichnyyDokument(MaketKomponovkiDannykh,\ DannyeRasshifrovkiObekt);\nOtobrazitPanelRezultatov();.Description=InacheEsli Item.s \= 1 Togda\nVariant Builder.\nSkhemaKomponovkiDannykh \= PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov.NaytiPoIdentifikatoru(Items.DerevoOtchetov.TekushchayaStroka)).Data);\nKomponovshchikMaketa \= New KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh \= KomponovshchikMaketa.Execute(DataCompositionSchema, Report.KomponovshchikNastroek.Settings, DannyeRasshifrovkiObekt);\nAdresSkhemyIspolnennogoOtcheta \= PomestitVoVremennoeKhranilishche(DataCompositionSchema, ?(AdresSkhemyIspolnennogoOtcheta <> "", AdresSkhemyIspolnennogoOtcheta, UUIDString));\nVyvestiMaketKomponovkiDannykhVTablichnyyDokument(MaketKomponovkiDannykh, DannyeRasshifrovkiObekt);\nOtobrazitPanelRezultatov();\nInacheEsli Item.TipStroki \= 2 Togda\nNastroyki Builder.\nSkhemaKomponovkiDannykh \= PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov.NaytiPoIdentifikatoru(Items.DerevoOtchetov.TekushchayaStroka)).Data);\nKomponovshchikMaketa \= New KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh \= KomponovshchikMaketa.Execute(DataCompositionSchema, Report.KomponovshchikNastroek.GetSettings(), DannyeRasshifrovkiObekt);\nAdresSkhemyIspolnennogoOtcheta \= PomestitVoVremennoeKhranilishche(DataCompositionSchema, ?(AdresSkhemyIspolnennogoOtcheta <> "", AdresSkhemyIspolnennogoOtcheta, UUIDString));\nVyvestiMaketKomponovkiDannykhVTablichnyyDokument(MaketKomponovkiDannykh, DannyeRasshifrovkiObekt);\nOtobrazitPanelRezultatov();
