Method.СформироватьНаСервереВКоллекцию.Comment.ИначеЕсли\ Элемент\.ТипСтроки\ \=\ 1\ Togda\nVariant\ Builder\.\nSkhemaKomponovkiDannykh\ \=\ PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov\.NaytiPoIdentifikatoru(Items\.DerevoOtchetov\.TekushchayaStroka))\.Data);\nKomponovshchikMaketa\ \=\ New\ KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh\ \=\ KomponovshchikMaketa\.Execute(DataCompositionSchema,\ Report\.KomponovshchikNastroek\.Settings\ ,\ ,\ ,\ Type("GeneratorMaketaKomponovkiDannykhDlyaKollektsiiZnacheniy"));\nVyvestiMaketKomponovkiDannykhVKollektsiyu(MaketKomponovkiDannykh);\nOtobrazitPanelRezultatov();\nInacheEsli\ Item\.TipStroki\ \=\ 2\ Togda\nNastroyki\ Builder\.\nSkhemaKomponovkiDannykh\ \=\ PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov\.NaytiPoIdentifikatoru(Items\.DerevoOtchetov\.TekushchayaStroka))\.Data);\nKomponovshchikMaketa\ \=\ New\ KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh\ \=\ KomponovshchikMaketa\.Execute(DataCompositionSchema,\ Report\.KomponovshchikNastroek\.GetSettings()\ ,\ ,\ ,\ Type("GeneratorMaketaKomponovkiDannykhDlyaKollektsiiZnacheniy"));\nVyvestiMaketKomponovkiDannykhVKollektsiyu(MaketKomponovkiDannykh);\nOtobrazitPanelRezultatov();.Description=InacheEsli Item.TipStroki \= 1 Togda\nVariant Builder.\nSkhemaKomponovkiDannykh \= PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov.NaytiPoIdentifikatoru(Items.DerevoOtchetov.TekushchayaStroka)).Data);\nKomponovshchikMaketa \= New KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh \= KomponovshchikMaketa.Execute(DataCompositionSchema, Report.KomponovshchikNastroek.Settings , , , Type("GeneratorMaketaKomponovkiDannykhDlyaKollektsiiZnacheniy"));\nVyvestiMaketKomponovkiDannykhVKollektsiyu(MaketKomponovkiDannykh);\nOtobrazitPanelRezultatov();\nInacheEsli Item.TipStroki \= 2 Togda\nNastroyki Builder.\nSkhemaKomponovkiDannykh \= PoluchitSkhemuKomponovkiDannykh(NaytiElementDerevaOtchet(DerevoOtchetov.NaytiPoIdentifikatoru(Items.DerevoOtchetov.TekushchayaStroka)).Data);\nKomponovshchikMaketa \= New KomponovshchikMaketaKomponovkiDannykh;\nMaketKomponovkiDannykh \= KomponovshchikMaketa.Execute(DataCompositionSchema, Report.KomponovshchikNastroek.GetSettings() , , , Type("GeneratorMaketaKomponovkiDannykhDlyaKollektsiiZnacheniy"));\nVyvestiMaketKomponovkiDannykhVKollektsiyu(MaketKomponovkiDannykh);\nOtobrazitPanelRezultatov();
